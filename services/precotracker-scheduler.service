[Unit]
Description=PriceTracker - Local Scheduler Daemon
After=network.target

[Service]
Type=simple
User=iago
WorkingDirectory=/home/iago/Documentos/Pessoal/price-tracker/backend
ExecStart=/home/iago/Documentos/Pessoal/price-tracker/.venv/bin/python scheduler.py
Restart=on-failure

[Install]
WantedBy=multi-user.target
